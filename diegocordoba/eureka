#!/bin/bash

# Eureka 1.0 - Optimized Execution Engine
# Resolves yfinance 'Adj Close' KeyError

CAPITAL_VAL=${1:-1000000}

python3 - << END
import yfinance as yf
import numpy as np
import pandas as pd

tickers = ["SNDK", "SNXX", "CASH"]
capital = $CAPITAL_VAL

# Download with progress off and auto_adjust=True (default)
# This results in 'Close' being the adjusted price
data = yf.download(tickers, period="1y", progress=False)['Close']

if data.empty:
    print("Error: No data fetched.")
    exit()

# Risk Parity Logic
returns = data.pct_change().dropna()
vols = returns.std() * np.sqrt(252)
inv_vols = 1 / vols
weights = inv_vols / inv_vols.sum()
prices = data.iloc[-1]

print(f"{'TICKER':<10} | {'WEIGHT':<10} | {'PRICE':<10} | {'ALLOCATION'}")
print("-" * 65)

for t in tickers:
    alloc = weights[t] * capital
    print(f"{t:<10} | {weights[t]:>8.2%} | {prices[t]:>9.2f} | \${alloc:>15,.2f}")
END
